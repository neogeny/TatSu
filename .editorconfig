# top-most EditorConfig file
root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 4
max_line_length = off

[*.py]
max_line_length = 120

[*.{yml,yaml,json}]
indent_size = 2
