Grammar(
  name='CALC',
  directives={'grammar': 'CALC'},
  keywords=(),
  rules=(
    Rule(
      name='start',
      params=(),
      kwparams={},
      decorators=[],
      is_name=False,
      is_tokn=False,
      no_memo=False,
      no_stak=False,
      is_memo=True,
      is_lrec=False,
      exp=Sequence([Call('expression'), EOF()])
    ),
    Rule(
      name='expression',
      params=(),
      kwparams={},
      decorators=[],
      is_name=False,
      is_tokn=False,
      no_memo=False,
      no_stak=False,
      is_memo=False,
      is_lrec=True,
      exp=Choice(
        [Option(Call('addition')), Option(Call('subtraction')), Option(Call('term'))]
      )
    ),
    Rule(
      name='addition',
      params=['Add'],
      kwparams={},
      decorators=[],
      is_name=False,
      is_tokn=False,
      no_memo=False,
      no_stak=False,
      is_memo=False,
      is_lrec=False,
      exp=Sequence(
        [
          Named(name='left', exp=Call('expression')),
          Token('+'),
          Cut(),
          Named(name='right', exp=Call('term'))
        ]
      )
    ),
    Rule(
      name='subtraction',
      params=['Subtract'],
      kwparams={},
      decorators=[],
      is_name=False,
      is_tokn=False,
      no_memo=False,
      no_stak=False,
      is_memo=False,
      is_lrec=False,
      exp=Sequence(
        [
          Named(name='left', exp=Call('expression')),
          Token('-'),
          Cut(),
          Named(name='right', exp=Call('term'))
        ]
      )
    ),
    Rule(
      name='term',
      params=(),
      kwparams={},
      decorators=[],
      is_name=False,
      is_tokn=False,
      no_memo=False,
      no_stak=False,
      is_memo=False,
      is_lrec=True,
      exp=Choice(
        [
          Option(Call('multiplication')),
          Option(Call('division')),
          Option(Call('factor'))
        ]
      )
    ),
    Rule(
      name='multiplication',
      params=['Multiply'],
      kwparams={},
      decorators=[],
      is_name=False,
      is_tokn=False,
      no_memo=False,
      no_stak=False,
      is_memo=False,
      is_lrec=False,
      exp=Sequence(
        [
          Named(name='left', exp=Call('term')),
          Token('*'),
          Cut(),
          Named(name='right', exp=Call('factor'))
        ]
      )
    ),
    Rule(
      name='division',
      params=['Divide'],
      kwparams={},
      decorators=[],
      is_name=False,
      is_tokn=False,
      no_memo=False,
      no_stak=False,
      is_memo=False,
      is_lrec=False,
      exp=Sequence(
        [
          Named(name='left', exp=Call('term')),
          Token('/'),
          Cut(),
          Named(name='right', exp=Call('factor'))
        ]
      )
    ),
    Rule(
      name='factor',
      params=(),
      kwparams={},
      decorators=[],
      is_name=False,
      is_tokn=False,
      no_memo=False,
      no_stak=False,
      is_memo=True,
      is_lrec=False,
      exp=Choice(
        [
          Option(Sequence([Token('('), Cut(), Override(Call('expression')), Token(')')])),
          Option(Call('number'))
        ]
      )
    ),
    Rule(
      name='number',
      params=['int'],
      kwparams={},
      decorators=[],
      is_name=False,
      is_tokn=False,
      no_memo=False,
      no_stak=False,
      is_memo=True,
      is_lrec=False,
      exp=Pattern('\\d+')
    )
  )
)